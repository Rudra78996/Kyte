# API
API_PORT=3000
NODE_ENV=development
RELEASE_VERSION=local
BASE_DOMAIN=deployly.local
SITES_DOMAIN=sites.deployly.local
DOMAIN_CNAME_TARGET=
DASHBOARD_ORIGINS=http://localhost,http://localhost:3002

# Production release attestations. Keep these false locally. Set them to true
# only after completing the corresponding provider-side actions and local gate.
PRODUCTION_CREDENTIALS_ROTATED=false
GITHUB_STORED_TOKENS_REVOKED=false
LOCAL_SECURITY_TESTS_PASSED=false

# Required by both API and worker. Generate once with:
# openssl rand -base64 32
ENCRYPTION_KEY=

# Worker
WORKER_PORT=3001
BUILD_MAX_WORKSPACE_BYTES=1500000000
BUILD_MAX_LOG_BYTES=5000000

# Web
WEB_PORT=3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:80/api
NEXT_PUBLIC_SITES_DOMAIN=sites.localhost
NEXT_PUBLIC_SITES_SCHEME=http
# Public, build-time FormSubmit AJAX endpoint used by /contact.
# Example: https://formsubmit.co/ajax/support@example.com
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=

# Clerk
# Use Clerk test keys locally and a separate production instance with pk_live_ /
# sk_live_ keys in production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# Comma-separated browser origins allowed to send Clerk session tokens.
CLERK_AUTHORIZED_PARTIES=http://localhost,http://localhost:3000
# Comma-separated verified Clerk emails that can access /admin.
ADMIN_EMAILS=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Required: at least 32 random bytes. Generate with `openssl rand -base64 32`.
GITHUB_WEBHOOK_SECRET=
GITHUB_CALLBACK_URL=http://localhost/github/callback
# Public HTTPS endpoint GitHub can reach (use a tunnel URL for local testing).
WEBHOOK_CALLBACK_URL=https://your-domain.example/api/webhooks/github

# Postgres
POSTGRES_DB=deployly
POSTGRES_USER=postgres
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:REPLACE_WITH_PASSWORD@postgres:5432/deployly

# Redis
# Generate with: openssl rand -hex 24
REDIS_PASSWORD=
REDIS_URL=redis://:REPLACE_WITH_PASSWORD@redis:6379

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=kyte-root
# Generate independent root and application passwords with:
# openssl rand -hex 24
MINIO_ROOT_PASSWORD=
MINIO_ACCESS_KEY=kyte-app
MINIO_SECRET_KEY=
MINIO_BUCKET=deployly-projects
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Nginx
NGINX_PORT=80
