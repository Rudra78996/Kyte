generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  passwordHash       String?
  clerkId            String?              @unique
  githubId           String?              @unique
  username           String?
  avatarUrl          String?
  projects           Project[]
  githubConnections  GitHubConnection[]
  organizationMembers OrganizationMember[]
  notifications      Notification[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model Organization {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  members   OrganizationMember[]
  projects  Project[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

model Project {
  /// A partial unique database index permits only one non-null webhookId per user.
  id               String             @id @default(cuid())
  name             String
  description      String?
  repoUrl          String
  subdomain        String             @unique
  userId           String
  user             User               @relation(fields: [userId], references: [id])
  organizationId   String?
  organization     Organization?      @relation(fields: [organizationId], references: [id])
  activeDeployId   String?            @unique
  activeDeploy     Deployment?        @relation("ActiveDeployment", fields: [activeDeployId], references: [id])
  deployments      Deployment[]       @relation("ProjectDeployments")
  requestLogs      RequestLog[]       @relation("ProjectRequestLogs")
  environmentVariables EnvironmentVariable[] @relation("ProjectEnvironmentVariables")
  customDomains    CustomDomain[]     @relation("ProjectCustomDomains")
  githubConnection GitHubConnection?
  webhookId        String?
  githubRepositoryId String?
  preset           String?            @default("React")
  rootDirectory    String?            @default("./")
  buildCommand     String?            @default("npm run build")
  outputDirectory  String?            @default("dist")
  branch           String?            @default("main")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([githubRepositoryId, branch])
}

model Deployment {
  id               String               @id @default(cuid())
  projectId        String
  project          Project              @relation("ProjectDeployments", fields: [projectId], references: [id])
  status           Status               @default(QUEUED)
  s3Prefix         String
  commitSha        String
  commitMessage    String?
  repoUrl          String
  branch           String
  deployedBy       String
  triggerSource    DeploymentTrigger    @default(MANUAL)
  logs             DeploymentLogChunk[]
  deployedAt       DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  activeForProject Project?             @relation("ActiveDeployment")
}

model DeploymentLogChunk {
  id           String     @id @default(cuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  sequence     Int
  content      String
  stream       LogStream
  createdAt    DateTime   @default(now())

  @@unique([deploymentId, sequence, stream])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("INFO") // SUCCESS, ERROR, INFO
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GitHubConnection {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId            String?   @unique
  project              Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  githubUserId         String    @unique
  githubUsername       String
  accessTokenEncrypted String?
  tokenIv              String?
  tokenAuthTag         String?
  scopes               String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

enum Status {
  QUEUED
  BUILDING
  UPLOADING
  SUCCESS
  FAILED
  TIMEOUT
  CANCELED
}

enum DeploymentTrigger {
  MANUAL
  WEBHOOK
}

enum LogStream {
  STDOUT
  STDERR
}

model RequestLog {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation("ProjectRequestLogs", fields: [projectId], references: [id], onDelete: Cascade)
  
  timestamp    DateTime @default(now())
  
  method       String   
  path         String   
  statusCode   Int      
  responseTime Int      // in milliseconds
  
  ipAddress    String?
  country      String?  
  countryCode  String?  

  @@index([projectId, timestamp])
}

model EnvironmentVariable {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation("ProjectEnvironmentVariables", fields: [projectId], references: [id], onDelete: Cascade)
  key            String
  encryptedValue String
  iv             String
  authTag        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectId, key])
}

model CustomDomain {
  id                String   @id @default(cuid())
  domainName        String   @unique
  projectId         String
  project           Project  @relation("ProjectCustomDomains", fields: [projectId], references: [id], onDelete: Cascade)
  verificationToken String
  status            String   @default("pending") // pending, verified
  verifiedAt        DateTime?
  createdAt         DateTime @default(now())

  @@index([projectId])
}
