{
	# Caddy calls this before issuing an on-demand certificate. The API only
	# allows domains that have completed TXT verification.
	on_demand_tls {
		ask http://api:3000/api/caddy/check-domain
	}
}

# Local dashboard and API entry point.
http://localhost {
	header {
		-Server
		-X-Powered-By
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
	}

	@deployment_api path /api/serve /api/serve/*
	handle @deployment_api {
		respond 404
	}

	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:3000
	}

	handle {
		reverse_proxy web:3000
	}
}

# Local project URLs deliberately use a different parent host from the dashboard.
http://*.sites.localhost {
	header {
		-Server
		-X-Powered-By
		-Set-Cookie
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
	rewrite * /serve/host/{host}{uri}
	reverse_proxy api:3000 {
		header_up -Cookie
		header_up -Authorization
	}
}

# Kyte's public dashboard and API. Caddy provisions and renews this certificate.
{$BASE_DOMAIN} {
	header {
		-Server
		-X-Powered-By
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
	}

	@deployment_api path /api/serve /api/serve/*
	handle @deployment_api {
		respond 404
	}

	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:3000
	}

	handle {
		reverse_proxy web:3000
	}
}

# Verified custom hostnames are served by the API from the active deployment.
# The certificate is requested only after /api/caddy/check-domain approves it.
https:// {
	tls {
		on_demand
	}

	header {
		-Server
		-X-Powered-By
		-Set-Cookie
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
	rewrite * /serve/host/{host}{uri}
	reverse_proxy api:3000 {
		header_up -Cookie
		header_up -Authorization
	}
}
