{
	# Set this in /etc/caddy/Caddyfile for ACME account notifications.
	email admin@example.com

	# This must appear only once in a shared Caddyfile. It protects Kyte's
	# catch-all custom-domain TLS block from certificate-issuance abuse.
	on_demand_tls {
		ask http://127.0.0.1:3000/api/caddy/check-domain
	}
}

# Kyte dashboard and API. For the one-domain setup use app.kyte.rudrx.cloud.
app.kyte.rudrx.cloud {
	header {
		-Server
		-X-Powered-By
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
	}

	@deployment_api path /api/serve /api/serve/*
	handle @deployment_api {
		respond 404
	}

	handle /api/* {
		uri strip_prefix /api
		reverse_proxy 127.0.0.1:3000
	}

	handle {
		reverse_proxy 127.0.0.1:3002
	}
}

# Other applications use their own fixed hostname blocks. Add one per project.
blog.example.com {
	reverse_proxy 127.0.0.1:4000
}

status.example.com {
	reverse_proxy 127.0.0.1:4100
}

# Kyte generated subdomains and verified customer domains. Keep this generic
# block after all fixed hostnames for the other applications on this VPS.
https:// {
	tls {
		on_demand
	}

	# Generated subdomains are untrusted even when they share the same
	# registered domain as the dashboard. The sandbox intentionally omits
	# allow-same-origin so project JavaScript cannot set parent-domain cookies.
	@generated_site host *.site.kyte.rudrx.cloud
	handle @generated_site {
		header {
			-Server
			-X-Powered-By
			-Set-Cookie
			Content-Security-Policy "sandbox allow-downloads allow-forms allow-modals allow-pointer-lock allow-popups allow-popups-to-escape-sandbox allow-presentation allow-scripts"
			Cross-Origin-Opener-Policy "same-origin"
			Origin-Agent-Cluster "?1"
			X-Content-Type-Options "nosniff"
			Referrer-Policy "strict-origin-when-cross-origin"
			Permissions-Policy "camera=(), microphone=(), geolocation=()"
		}
		rewrite * /serve/host/{host}{uri}
		reverse_proxy 127.0.0.1:3000 {
			header_up -Cookie
			header_up -Authorization
		}
	}

	handle {
		header {
			-Server
			-X-Powered-By
			-Set-Cookie
			X-Content-Type-Options "nosniff"
			Referrer-Policy "strict-origin-when-cross-origin"
			Permissions-Policy "camera=(), microphone=(), geolocation=()"
		}
		rewrite * /serve/host/{host}{uri}
		reverse_proxy 127.0.0.1:3000 {
			header_up -Cookie
			header_up -Authorization
		}
	}
}
